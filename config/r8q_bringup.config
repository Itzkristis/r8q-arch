# r8q milestone-1/2 config fragment — merged on top of arm64 defconfig.
# Philosophy (garnet lesson): bring-up-critical drivers BUILT-IN, no module ordering hell.

# --- Core boot path (EFI stub via GRUB/Mu-Silicium) ---
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_FB=y
CONFIG_FB_EFI=y
CONFIG_FB_SIMPLE=y
CONFIG_SYSFB_SIMPLEFB=y
CONFIG_DRM=y
CONFIG_DRM_SIMPLEDRM=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE_DETECT_PRIMARY=y
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_FHANDLE=y

# --- Qualcomm SM8250 platform core, built-in ---
CONFIG_ARCH_QCOM=y
CONFIG_QCOM_SCM=y
CONFIG_PINCTRL_SM8250=y
CONFIG_SM_GCC_8250=y
CONFIG_QCOM_RPMH=y
CONFIG_QCOM_RPMHPD=y
CONFIG_QCOM_COMMAND_DB=y
CONFIG_REGULATOR_QCOM_RPMH=y
CONFIG_INTERCONNECT=y
CONFIG_INTERCONNECT_QCOM=y
CONFIG_INTERCONNECT_QCOM_SM8250=y
CONFIG_INTERCONNECT_QCOM_OSM_L3=y
CONFIG_ARM_SMMU=y
CONFIG_ARM_SMMU_QCOM=y
CONFIG_QCOM_PDC=y
CONFIG_QCOM_SMEM=y
CONFIG_QCOM_SOCINFO=y
CONFIG_QCOM_STATS=y
CONFIG_ARM_QCOM_CPUFREQ_HW=y
CONFIG_QCOM_CLK_RPMH=y
CONFIG_SPMI=y
CONFIG_SPMI_MSM_PMIC_ARB=y
CONFIG_PINCTRL_QCOM_SPMI_PMIC=y
CONFIG_QCOM_TSENS=y
CONFIG_NVMEM_QCOM_QFPROM=y
CONFIG_NVMEM_SPMI_SDAM=y
CONFIG_POWER_RESET_QCOM_PON=y
CONFIG_INPUT_PM8941_PWRKEY=y
CONFIG_RTC_DRV_PM8XXX=y

# --- UFS storage, built-in (milestone 2) ---
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_SCSI_UFSHCD=y
CONFIG_SCSI_UFSHCD_PLATFORM=y
CONFIG_SCSI_UFS_QCOM=y
CONFIG_PHY_QCOM_QMP=y
CONFIG_PHY_QCOM_QMP_UFS=y

# --- Filesystems for ESP logging + Arch rootfs ---
CONFIG_VFAT_FS=y
CONFIG_FAT_DEFAULT_UTF8=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y
CONFIG_EXT4_FS=y
CONFIG_TMPFS=y

# --- USB gadget path (milestone 4 prep; dwc3 + hsphy are in the DT) ---
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_QCOM=y
CONFIG_PHY_QCOM_USB_SNPS_FEMTO_V2=y
CONFIG_USB_GADGET=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_NCM=y
CONFIG_USB_CONFIGFS_ECM=y
CONFIG_USB_CONFIGFS_SERIAL=y
CONFIG_USB_CONFIGFS_MASS_STORAGE=y

# --- Debugging / diagnostics (garnet playbook) ---
CONFIG_PSTORE=y
CONFIG_PSTORE_CONSOLE=y
CONFIG_PSTORE_PMSG=y
CONFIG_PSTORE_RAM=y
CONFIG_DEBUG_FS=y
CONFIG_DYNAMIC_DEBUG=y
CONFIG_FTRACE=y
CONFIG_FUNCTION_TRACER=y
CONFIG_KPROBES=y
CONFIG_KPROBE_EVENTS=y
CONFIG_HIST_TRIGGERS=y
CONFIG_MAGIC_SYSRQ=y

# --- M1: single-file EFI boot (kernel = BOOTAA64.EFI, initramfs embedded, cmdline forced) ---
CONFIG_CMDLINE="earlycon=efifb keep_bootcon console=tty0 loglevel=8 ignore_loglevel clk_ignore_unused pd_ignore_unused arm-smmu.disable_bypass=0 iommu.passthrough=1 panic=30"
CONFIG_CMDLINE_FORCE=y
CONFIG_INITRAMFS_SOURCE="/home/sitsirk/r8q_linux/irfs /home/sitsirk/r8q_linux/irfs.devnodes"
CONFIG_INITRAMFS_ROOT_UID=0
CONFIG_INITRAMFS_ROOT_GID=0

# --- Misc userspace needs ---
CONFIG_AUTOFS_FS=y
CONFIG_CGROUPS=y
CONFIG_NAMESPACES=y
CONFIG_SECCOMP=y
CONFIG_BINFMT_SCRIPT=y

# Touchscreen stack (session 5): geni I2C + GPI DMA as modules (loaded by
# r8q-touch.service; SE5 needs i2c-qcom-geni r8q_force_fifo=1), FTS5CU56A driver.
CONFIG_I2C_QCOM_GENI=m
CONFIG_QCOM_GPI_DMA=m
CONFIG_TOUCHSCREEN_FTS5CU56A=m
